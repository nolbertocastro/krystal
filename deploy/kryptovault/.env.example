# ─────────────────────────────────────────────────────────────────────────
# mymind (Karakeep fork) — KryptoVault env template
# Copy to .env, fill the secrets, then run `docker compose up -d`.
# ─────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 36
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_36

# The URL your iPhone, Chrome extension, and OpenClaw will hit.
# Use the Tailscale MagicDNS name (recommended) once Tailscale is wired up.
# Examples:
#   http://192.168.8.233:3000               LAN only
#   http://kryptovault.your-tail.ts.net:3000  via Tailscale
NEXTAUTH_URL=http://kryptovault.YOUR-TAILNET.ts.net:3000

# Set to false after you create your account so nobody else can sign up.
DISABLE_SIGNUPS=false

# ── Meilisearch (full-text search) ───────────────────────────────────────
# Generate with:  openssl rand -base64 36
MEILI_MASTER_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_36

# ── AI (DeepSeek V3.2 — Krystal Phase 3 default) ─────────────────────────
# DeepSeek V3.2 via OpenAI-compatible endpoint. Cheapest credible model
# with frontier quality: $0.14 / $0.28 per 1M input/output tokens, plus
# a 90% cache-hit discount ($0.028/M input). Since tagging sends the same
# system prompt across every card, effective cost is closer to a few cents
# per thousand cards.
#
# Sign up + generate a key: https://platform.deepseek.com/api_keys
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_BASE_URL=https://api.deepseek.com
INFERENCE_TEXT_MODEL=deepseek-chat
INFERENCE_IMAGE_MODEL=deepseek-chat
# Force provider so the OpenAI-compatible path is used unconditionally
# (Karakeep otherwise auto-picks Anthropic if any ANTHROPIC_API_KEY is set).
INFERENCE_PROVIDER=openai

# Turn on automatic tagging + summarization out of the box.
INFERENCE_ENABLE_AUTO_TAGGING=true
INFERENCE_ENABLE_AUTO_SUMMARIZATION=true

# DeepSeek supports up to 164K context; keep this modest for cost control.
INFERENCE_CONTEXT_LENGTH=16000
INFERENCE_MAX_OUTPUT_TOKENS=2048

# ── Legacy Anthropic config (kept for reference / fallback) ──────────────
# To switch back to Claude, set INFERENCE_PROVIDER=anthropic above and
# uncomment these:
# ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX
# INFERENCE_ANTHROPIC_TEXT_MODEL=claude-haiku-4-5
# INFERENCE_ANTHROPIC_IMAGE_MODEL=claude-haiku-4-5

# ── Semantic search (optional, for OpenClaw "ask me about my archive") ───
# Anthropic has no embedding model; Voyage AI is their official partner.
# Sign up at https://www.voyageai.com/ — first 50M tokens are free.
# Uncomment to enable semantic search across your archive.
# VOYAGE_API_KEY=pa-XXXXXXXXXXXXXXXXXXXXXXXX
# EMBEDDING_TEXT_MODEL=voyage-3
# EMBEDDING_DIMENSIONS=1024
# EMBEDDING_ENABLE_AUTO_INDEXING=true

# ── Crawler / archival ───────────────────────────────────────────────────
CRAWLER_FULL_PAGE_ARCHIVE=true
CRAWLER_FULL_PAGE_SCREENSHOT=true
CRAWLER_VIDEO_DOWNLOAD=false   # set to true if you want yt-dlp on saved video links

# ── Misc ─────────────────────────────────────────────────────────────────
# Container internals — do not change unless you know what you're doing.
DATA_DIR=/data
